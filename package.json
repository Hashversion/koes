{
  "name": "koes",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo clean && rimraf node_modules .turbo",
    "dev": "turbo run dev",
    "fmt": "oxfmt",
    "postinstall": "lefthook install",
    "lint": "turbo run lint",
    "static:build": "turbo build -F static",
    "static:dev": "turbo dev -F static",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.50.0",
    "portless": "^0.13.0",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.12",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.22.3"
  },
  "packageManager": "pnpm@10.33.4"
}
